<style>
:root{
  --indigo:#28344A;
  --indigo-deep:#1B2434;
  --paper:#F1ECE2;
  --paper-deep:#E7E0CF;
  --ink:#2A2520;
  --ochre:#C8902E;
  --madder:#8B3A3A;
  --thread:#B9AE9A;
  --display: 'Fraunces', serif;
  --body: 'Source Serif 4', Georgia, serif;
  --mono: 'IBM Plex Mono', monospace;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  font-family:var(--body);
  color:var(--ink);
  background:var(--paper);
  line-height:1.65;
  font-size:18px;
}
::selection{background:var(--ochre);color:#fff;}

a{color:var(--indigo);text-decoration-thickness:1px;}
h1,h2,h3{font-family:var(--display);font-weight:600;margin:0;}

/* ---------- Thread nav ---------- */
.thread-nav{
  position:fixed;
  left:0; top:0; bottom:0;
  width:18px;
  z-index:50;
  display:flex;
  align-items:center;
}
.thread-nav ul{
  list-style:none;
  margin:0; padding:0;
  position:relative;
  height:78vh;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}
.thread-nav ul::before{
  content:'';
  position:absolute;
  left:8px; top:0; bottom:0;
  width:2px;
  background:var(--thread);
  opacity:.5;
}
.thread-nav li{position:relative;}
.thread-nav a{
  display:flex;
  align-items:center;
  height:14px;
  text-decoration:none;
  position:relative;
}
.thread-nav .knot{
  width:7px; height:7px;
  border-radius:50%;
  background:var(--paper);
  border:2px solid var(--thread);
  margin-left:5px;
  display:block;
  transition:background .25s, border-color .25s, transform .25s;
  position:relative;
  z-index:2;
}
.thread-nav a.active .knot, .thread-nav a:hover .knot{
  background:var(--ochre);
  border-color:var(--ochre);
  transform:scale(1.3);
}
.thread-label{
  position:absolute;
  left:24px;
  top:50%;
  transform:translateY(-50%);
  white-space:nowrap;
  font-family:var(--mono);
  font-size:11px;
  letter-spacing:.04em;
  text-transform:uppercase;
  color:var(--indigo);
  background:var(--paper);
  padding:2px 6px;
  border-radius:2px;
  opacity:0;
  pointer-events:none;
  transition:opacity .15s;
}
.thread-nav a:hover .thread-label, .thread-nav a.active .thread-label{opacity:1;}

@media (max-width:760px){
  .thread-nav{display:none;}
}

/* ---------- Hero ---------- */
.hero{
