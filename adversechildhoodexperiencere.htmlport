  flex-direction:column;
  justify-content:center;
  padding:8vh 8vw;
  position:relative;
  overflow:hidden;
}
.hero::before{
  /* woven thread texture, faint */
  content:'';
  position:absolute; inset:0;
  background-image:
    repeating-linear-gradient(90deg, rgba(241,236,226,0.035) 0 1px, transparent 1px 26px),
    repeating-linear-gradient(0deg, rgba(241,236,226,0.035) 0 1px, transparent 1px 26px);
